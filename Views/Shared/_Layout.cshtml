<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ExpenseTracker</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
    <style>
        body {
            background-color: #f1efe8;
            font-family: 'Segoe UI', sans-serif;
        }

        .sidebar {
            width: 220px;
            min-height: 100vh;
            background-color: #185FA5;
            position: fixed;
            top: 0;
            left: 0;
            display: flex;
            flex-direction: column;
            padding: 1.5rem 0;
            z-index: 100;
        }

        .sidebar-logo {
            color: white;
            font-size: 16px;
            font-weight: 600;
            padding: 0 1.25rem 1.5rem;
            display: flex;
            align-items: center;
            gap: 8px;
            text-decoration: none;
        }

        .sidebar-logo:hover {
            color: white;
        }

        .nav-link-side {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 10px 1.25rem;
            color: rgba(255,255,255,0.75);
            font-size: 14px;
            text-decoration: none;
            transition: all 0.15s;
            border-left: 3px solid transparent;
        }

        .nav-link-side:hover {
            background: rgba(255,255,255,0.1);
            color: white;
        }

        .nav-link-side.active {
            background: rgba(255,255,255,0.15);
            color: white;
            border-left: 3px solid white;
        }

        .nav-link-side i {
            font-size: 18px;
        }

        .sidebar-bottom {
            margin-top: auto;
            padding: 1rem 1.25rem 0;
        }

        .user-pill {
            background: rgba(255,255,255,0.1);
            border-radius: 8px;
            padding: 8px 10px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .user-avatar {
            width: 30px;
            height: 30px;
            border-radius: 50%;
            background: #B5D4F4;
            color: #0C447C;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 12px;
            font-weight: 600;
            flex-shrink: 0;
        }

        .user-email {
            color: white;
            font-size: 11px;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            max-width: 130px;
        }

        .logout-btn {
            background: none;
            border: none;
            color: rgba(255,255,255,0.7);
            font-size: 11px;
            padding: 4px 0;
            cursor: pointer;
            text-align: left;
        }

        .logout-btn:hover {
            color: white;
        }

        .main-content {
            margin-left: 220px;
            padding: 2rem;
            min-height: 100vh;
        }

        .card {
            border: 0.5px solid #e0ddd6 !important;
            border-radius: 12px !important;
            box-shadow: none !important;
        }
    </style>
</head>
<body>

    @if (User.Identity!.IsAuthenticated)
    {
        <div class="sidebar">
            <a class="sidebar-logo" asp-controller="Dashboard" asp-action="Index">
                <i class="bi bi-wallet2"></i>
                ExpenseTracker
            </a>

            <nav>
                <a class="nav-link-side @(ViewContext.RouteData.Values["controller"]?.ToString() == "Dashboard" ? "active" : "")"
                   asp-controller="Dashboard" asp-action="Index">
                    <i class="bi bi-grid-1x2"></i> Dashboard
                </a>
                <a class="nav-link-side @(ViewContext.RouteData.Values["controller"]?.ToString() == "Expense" ? "active" : "")"
                   asp-controller="Expense" asp-action="Index">
                    <i class="bi bi-receipt"></i> Expenses
                </a>
                <a class="nav-link-side @(ViewContext.RouteData.Values["controller"]?.ToString() == "Category" ? "active" : "")"
                   asp-controller="Category" asp-action="Index">
                    <i class="bi bi-tag"></i> Categories
                </a>
                <a class="nav-link-side @(ViewContext.RouteData.Values["controller"]?.ToString() == "Budget" ? "active" : "")"
                   asp-controller="Budget" asp-action="Index">
                    <i class="bi bi-bullseye"></i> Budget
                </a>
            </nav>

            <div class="sidebar-bottom">
                <div class="user-pill">
                    <div class="user-avatar">
                        @User.Identity.Name?.Substring(0, 1).ToUpper()
                    </div>
                    <div>
                        <div class="user-email">@User.Identity.Name</div>
                        <form asp-area="Identity" asp-page="/Account/Logout" method="post">
                            <button type="submit" class="logout-btn">
                                <i class="bi bi-box-arrow-right"></i> Logout
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    }

    <div class="main-content @(!User.Identity.IsAuthenticated ? "ms-0" : "")"
         style="@(!User.Identity.IsAuthenticated ? "margin-left:0; background-color:#f1efe8; min-height:100vh;" : "")">
        @if (!User.Identity.IsAuthenticated)
        {
            <div style="position:fixed; top:0; left:0; right:0;
                        padding:1rem 2rem;
                        display:flex;
                        align-items:center;
                        gap:8px;
                        background-color:#185FA5;">
                <i class="bi bi-wallet2" style="color:white; font-size:20px;"></i>
                <span style="color:white; font-size:16px; font-weight:600;">
                    ExpenseTracker
                </span>
            </div>
            <div style="padding-top:60px;">
                @RenderBody()
            </div>
        }
        else
        {
            @RenderBody()
        }
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>