@model List<ExpenseTracker.Models.Category>
@{
    ViewData["Title"] = "Categories";
}

<div class="container-fluid px-4 py-3">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-1 fw-semibold">Categories</h2>
            <p class="text-muted small mb-0">Manage your expense categories</p>
        </div>
        <a asp-action="Create" class="btn btn-sm px-3 py-2"
           style="background-color: #185FA5; color: white; border-radius: 8px;">
            + Add Category
        </a>
    </div>

    @if (!Model.Any())
    {
        <div class="card p-5 text-center">
            <i class="bi bi-tag" style="font-size: 2.5rem; color: #185FA5;"></i>
            <h5 class="mt-3">No categories yet</h5>
            <p class="text-muted small">Create your first category to start tracking!</p>
            <a asp-action="Create" style="color: #185FA5;">+ Add your first category</a>
        </div>
    }
    else
    {
        <div class="row g-3">
            @foreach (var category in Model)
            {
                <div class="col-md-4 col-lg-3">
                    <div class="card p-3 h-100">
                        <div class="d-flex align-items-center gap-3 mb-3">
                            <div class="rounded-circle d-flex align-items-center
                                                justify-content-center"
                                 style="width:42px; height:42px;
                                                background-color: #E6F1FB; font-size: 20px;">
                                @(string.IsNullOrEmpty(category.Icon) ? "📁" : category.Icon)
                            </div>
                            <h6 class="mb-0 fw-semibold">@category.Name</h6>
                        </div>
                        <div class="d-flex gap-2 mt-auto">
                            <a asp-action="Edit" asp-route-id="@category.Id"
                               class="btn btn-sm w-50"
                               style="background-color:#E6F1FB;
                                              color:#185FA5; border-radius:6px;">
                                <i class="bi bi-pencil"></i> Edit
                            </a>
                            <a asp-action="Delete" asp-route-id="@category.Id"
                               class="btn btn-sm w-50"
                               style="background-color:#FCEBEB;
                                              color:#A32D2D; border-radius:6px;"
                               onclick="return confirm('Delete this category?')">
                                <i class="bi bi-trash"></i> Delete
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>