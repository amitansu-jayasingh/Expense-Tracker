@model ExpenseTracker.Models.Category
@{
    ViewData["Title"] = "Edit Category";
}

<div class="d-flex justify-content-center py-4">
    <div class="card p-4" style="width: 100%; max-width: 480px;">

        <div class="mb-4">
            <h4 class="fw-semibold mb-1">Edit Category</h4>
            <p class="text-muted small mb-0">Update your category details</p>
        </div>

        <form asp-action="Edit" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

            <input type="hidden" asp-for="Id" />

            <div class="mb-3">
                <label asp-for="Name" class="form-label small fw-semibold">
                    Category Name
                </label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger small"></span>
            </div>

            <div class="mb-4">
                <label asp-for="Icon" class="form-label small fw-semibold">
                    Icon (Emoji) — Optional
                </label>
                <input asp-for="Icon" class="form-control" />
            </div>

            <div class="d-flex gap-2">
                <button type="submit"
                        class="btn w-50"
                        style="background-color:#185FA5; color:white; border-radius:8px;">
                    Update Category
                </button>
                <a asp-action="Index"
                   class="btn w-50"
                   style="background-color:#f1efe8; color:#666; border-radius:8px;">
                    Cancel
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}