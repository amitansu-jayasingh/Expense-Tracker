@model ExpenseTracker.Models.Budget
@{
    ViewData["Title"] = "Set Budget";
}

<div class="d-flex justify-content-center py-4">
    <div class="card p-4" style="width:100%; max-width:460px;">

        <div class="mb-4">
            <h4 class="fw-semibold mb-1">Set Monthly Budget</h4>
            <p class="text-muted small mb-0">
                @DateTime.Now.ToString("MMMM yyyy")
            </p>
        </div>

        <form asp-action="SetBudget" method="post">
            <div asp-validation-summary="ModelOnly"
                 class="text-danger small mb-3"></div>

            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="Month" />
            <input type="hidden" asp-for="Year" />

            <div class="mb-4">
                <label asp-for="MonthlyLimit"
                       class="form-label small fw-semibold">
                    Monthly Limit (₹)
                </label>
                <input asp-for="MonthlyLimit"
                       class="form-control"
                       placeholder="e.g. 11000" />
                <span class="text-muted" style="font-size:11px;">
                    Your total spending limit for this month
                </span>
                <span asp-validation-for="MonthlyLimit"
                      class="text-danger small"></span>
            </div>

            <div class="d-flex gap-2">
                <button type="submit"
                        class="btn w-50"
                        style="background-color:#185FA5;
                               color:white;
                               border-radius:8px;">
                    Save Budget
                </button>
                <a asp-action="Index"
                   class="btn w-50"
                   style="background-color:#f1efe8;
                          color:#666;
                          border-radius:8px;">
                    Cancel
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}