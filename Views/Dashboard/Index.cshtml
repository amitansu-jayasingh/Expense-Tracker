@{
    ViewData["Title"] = "Dashboard";
    var totalSpent = (decimal)ViewBag.TotalSpent;
    var totalExpenses = (int)ViewBag.TotalExpenses;
    var remaining = (decimal)ViewBag.Remaining;
    var budget = ViewBag.Budget;
    var recentExpenses = ViewBag.RecentExpenses;
    var categorySpending = ViewBag.CategorySpending;
    var currentMonth = (string)ViewBag.CurrentMonth;
}

<div class="container-fluid px-4 py-3">

    <div class="mb-4">
        <h2 class="mb-1 fw-semibold">Dashboard</h2>
        <p class="text-muted small mb-0">
            @currentMonth — spending overview
        </p>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="card p-3">
                <p class="text-muted small mb-1">
                    <i class="bi bi-arrow-up-circle me-1"></i>Total Spent
                </p>
                <h3 class="fw-semibold mb-0" style="color:#A32D2D;">
                    ₹@totalSpent.ToString("N2")
                </h3>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card p-3">
                <p class="text-muted small mb-1">
                    <i class="bi bi-piggy-bank me-1"></i>Remaining Budget
                </p>
                <h3 class="fw-semibold mb-0"
                    style="color:@(remaining >= 0 ? "#0F6E56" : "#A32D2D")">
                    @(budget != null ? "₹" + ((decimal)remaining).ToString("N2") : "No budget set")
                </h3>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card p-3">
                <p class="text-muted small mb-1">
                    <i class="bi bi-list-ul me-1"></i>Total Expenses
                </p>
                <h3 class="fw-semibold mb-0">@totalExpenses</h3>
            </div>
        </div>
    </div>

    <div class="row g-3">
        <div class="col-md-6">
            <div class="card p-3 h-100">
                <h6 class="fw-semibold mb-3">Recent Expenses</h6>
                @if (recentExpenses.Count == 0)
                {
                    <p class="text-muted small">No expenses yet. Start adding!</p>
                }
                else
                {
                    @foreach (var expense in recentExpenses)
                    {
                        <div class="d-flex align-items-center gap-3 py-2"
                             style="border-bottom:0.5px solid #f0ede6;">
                            <div class="rounded-circle d-flex align-items-center
                                                justify-content-center flex-shrink-0"
                                 style="width:36px; height:36px;
                                                background-color:#E6F1FB;
                                                font-size:16px;">
                                @(expense.Category?.Icon ?? "📁")
                            </div>
                            <div class="flex-grow-1">
                                <div class="small fw-semibold">
                                    @expense.Title
                                </div>
                                <div class="small text-muted">
                                    @expense.Date.ToString("dd MMM yyyy")
                                </div>
                            </div>
                            <div class="small fw-semibold"
                                 style="color:#A32D2D;">
                                -₹@expense.Amount.ToString("N2")
                            </div>
                        </div>
                    }
                    <div class="mt-3">
                        <a asp-controller="Expense"
                           asp-action="Index"
                           style="color:#185FA5; font-size:13px;">
                            View all expenses →
                        </a>
                    </div>
                }
            </div>
        </div>

        <div class="col-md-6">
            <div class="card p-3 h-100">
                <h6 class="fw-semibold mb-3">Spending by Category</h6>
                @if (categorySpending.Count == 0)
                {
                    <p class="text-muted small">No data yet this month.</p>
                }
                else
                {
                    @foreach (var item in categorySpending)
                    {
                        var percent = totalSpent > 0 ?
                        (int)((item.Total / totalSpent) * 100) : 0;
                        <div class="mb-3">
                            <div class="d-flex justify-content-between mb-1">
                                <span class="small fw-semibold">
                                    @item.Category
                                </span>
                                @{
                                    var itemTotal = (decimal)item.Total;
                                }
                                <span class="small text-muted">
                                    ₹@itemTotal.ToString("N2")
                                    (@percent%)
                                </span>
                            </div>
                            <div class="progress"
                                 style="height:8px; border-radius:99px;">
                                <div class="progress-bar"
                                     style="width:@percent%;
                                                    background-color:#185FA5;
                                                    border-radius:99px;">
                                </div>
                            </div>
                        </div>
                    }
                    <div class="mt-2">
                        <a asp-controller="Budget"
                           asp-action="Index"
                           style="color:#185FA5; font-size:13px;">
                            View budget details →
                        </a>
                    </div>
                }
            </div>
        </div>
    </div>
</div>