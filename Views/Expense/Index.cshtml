@model List<ExpenseTracker.Models.Expense>
@{
    ViewData["Title"] = "Expenses";
}

<div class="container-fluid px-4 py-3">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-1 fw-semibold">Expenses</h2>
            <p class="text-muted small mb-0">Track your daily spending</p>
        </div>
        <a asp-action="Create" class="btn btn-sm px-3 py-2"
           style="background-color:#185FA5; color:white; border-radius:8px;">
            + Add Expense
        </a>
    </div>

    @if (!Model.Any())
    {
        <div class="card p-5 text-center">
            <i class="bi bi-receipt" style="font-size:2.5rem; color:#185FA5;"></i>
            <h5 class="mt-3">No expenses yet</h5>
            <p class="text-muted small">Start tracking your spending today!</p>
            <a asp-action="Create" style="color:#185FA5;">+ Add your first expense</a>
        </div>
    }
    else
    {
        <div class="card">
            <div class="table-responsive">
                <table class="table mb-0" style="font-size:14px;">
                    <thead style="background-color:#f8f9fa;">
                        <tr>
                            <th class="px-4 py-3">Title</th>
                            <th class="px-4 py-3">Category</th>
                            <th class="px-4 py-3">Date</th>
                            <th class="px-4 py-3">Note</th>
                            <th class="px-4 py-3">Amount</th>
                            <th class="px-4 py-3">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var expense in Model)
                        {
                            <tr style="border-bottom: 0.5px solid #f0ede6;">
                                <td class="px-4 py-3 fw-semibold">
                                    @expense.Title
                                </td>
                                <td class="px-4 py-3">
                                    <span class="badge px-2 py-1"
                                          style="background-color:#E6F1FB;
                                                         color:#185FA5;
                                                         border-radius:6px;
                                                         font-weight:500;">
                                        @(expense.Category?.Icon) @expense.Category?.Name
                                    </span>
                                </td>
                                <td class="px-4 py-3 text-muted">
                                    @expense.Date.ToString("dd MMM yyyy")
                                </td>
                                <td class="px-4 py-3 text-muted">
                                    @(string.IsNullOrEmpty(expense.Note) ? "-" : expense.Note)
                                </td>
                                <td class="px-4 py-3 fw-semibold"
                                    style="color:#A32D2D;">
                                    ₹@expense.Amount.ToString("N2")
                                </td>
                                <td class="px-4 py-3">
                                    <div class="d-flex gap-2">
                                        <a asp-action="Edit"
                                           asp-route-id="@expense.Id"
                                           class="btn btn-sm px-2"
                                           style="background-color:#E6F1FB;
                                                          color:#185FA5;
                                                          border-radius:6px;">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <a asp-action="Delete"
                                           asp-route-id="@expense.Id"
                                           class="btn btn-sm px-2"
                                           style="background-color:#FCEBEB;
                                                          color:#A32D2D;
                                                          border-radius:6px;"
                                           onclick="return confirm('Delete this expense?')">
                                            <i class="bi bi-trash"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                    <tfoot style="background-color:#f8f9fa;">
                        <tr>
                            <td colspan="4"
                                class="px-4 py-3 fw-semibold">
                                Total
                            </td>
                            <td class="px-4 py-3 fw-semibold"
                                style="color:#A32D2D;">
                                ₹@Model.Sum(e => e.Amount).ToString("N2")
                            </td>
                            <td></td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>
    }
</div>