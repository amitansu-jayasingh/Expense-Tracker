@page
@model LoginModel
@{
    ViewData["Title"] = "Login";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login — ExpenseTracker</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
    <style>
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Segoe UI', sans-serif;
            display: flex;
            height: 100vh;
            overflow: hidden;
            background: #f1efe8;
        }

        .left-panel {
            width: 45%;
            background-color: #1a3d6e;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            padding: 2.5rem 3rem;
            position: relative;
            overflow: hidden;
        }

        .circle-big {
            position: absolute;
            border-radius: 50%;
            background: rgba(255,255,255,0.05);
        }

        .circle1 {
            width: 300px;
            height: 300px;
            top: -80px;
            right: -80px;
        }

        .circle2 {
            width: 250px;
            height: 250px;
            bottom: -60px;
            left: -60px;
        }

        .logo {
            display: flex;
            align-items: center;
            gap: 10px;
            z-index: 1;
        }

        .logo-icon {
            width: 36px;
            height: 36px;
            background: rgba(255,255,255,0.15);
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

            .logo-icon i {
                font-size: 18px;
                color: white;
            }

        .logo span {
            color: white;
            font-size: 16px;
            font-weight: 500;
        }

        .left-content {
            z-index: 1;
        }

            .left-content h2 {
                color: white;
                font-size: 36px;
                font-weight: 700;
                line-height: 1.3;
                margin-bottom: 1rem;
            }

                .left-content h2 em {
                    color: #9FE1CB;
                    font-style: italic;
                }

            .left-content p {
                color: rgba(255,255,255,0.65);
                font-size: 14px;
                line-height: 1.7;
                margin-bottom: 2rem;
            }

        .feature-item {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 14px;
        }

        .feature-icon {
            width: 36px;
            height: 36px;
            border-radius: 50%;
            background: rgba(255,255,255,0.12);
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
        }

            .feature-icon i {
                font-size: 16px;
                color: #9FE1CB;
            }

        .feature-item span {
            color: rgba(255,255,255,0.85);
            font-size: 14px;
        }

        .left-bottom {
            z-index: 1;
            font-size: 12px;
            color: rgba(255,255,255,0.4);
        }

        .right-panel {
            flex: 1;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 2rem;
        }

        .login-card {
            background: white;
            border-radius: 16px;
            padding: 2.5rem;
            width: 100%;
            max-width: 400px;
            border: 0.5px solid #e0ddd6;
        }

        .card-eyebrow {
            font-size: 11px;
            font-weight: 700;
            letter-spacing: 1.5px;
            color: #185FA5;
            text-transform: uppercase;
            margin-bottom: 6px;
        }

        .card-title {
            font-size: 26px;
            font-weight: 700;
            color: #1a1a1a;
            margin-bottom: 1.75rem;
            line-height: 1.2;
        }

        .form-label {
            font-size: 13px;
            font-weight: 500;
            color: #444;
            margin-bottom: 6px;
            display: block;
        }

        .form-control {
            border: 1px solid #e5e5e5 !important;
            border-radius: 10px !important;
            font-size: 14px !important;
            padding: 11px 14px !important;
            background: #fafafa !important;
            width: 100%;
            color: #333;
        }

            .form-control:focus {
                border-color: #185FA5 !important;
                box-shadow: 0 0 0 3px rgba(24,95,165,0.08) !important;
                background: white !important;
                outline: none;
            }

        .remember-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin: 12px 0 20px;
        }

            .remember-row label {
                font-size: 13px;
                color: #666;
            }

        .forgot-link {
            font-size: 13px;
            color: #185FA5;
            text-decoration: none;
            font-weight: 500;
        }

        .divider {
            display: flex;
            align-items: center;
            gap: 10px;
            margin: 16px 0;
        }

            .divider hr {
                flex: 1;
                border: none;
                border-top: 1px solid #eee;
            }

            .divider span {
                font-size: 12px;
                color: #aaa;
            }

        .btn-login {
            width: 100%;
            padding: 13px;
            background-color: #1a3d6e;
            color: white;
            border: none;
            border-radius: 10px;
            font-size: 15px;
            font-weight: 500;
            cursor: pointer;
            transition: background 0.15s;
        }

            .btn-login:hover {
                background-color: #0C447C;
            }

        .bottom-link {
            text-align: center;
            margin-top: 0;
            font-size: 13px;
            color: #888;
        }

            .bottom-link a {
                color: #185FA5;
                font-weight: 600;
                text-decoration: none;
            }

        .credit {
            margin-top: 1.5rem;
            font-size: 13px;
            color: #999;
            text-align: center;
        }

            .credit a {
                color: #185FA5;
                font-weight: 600;
                text-decoration: none;
            }

                .credit a:hover {
                    text-decoration: underline;
                }
    </style>
</head>
<body>

    <div class="left-panel">
        <div class="circle-big circle1"></div>
        <div class="circle-big circle2"></div>

        <div class="logo">
            <div class="logo-icon">
                <i class="bi bi-wallet2"></i>
            </div>
            <span>ExpenseTracker</span>
        </div>

        <div class="left-content">
            <h2>Take <em>control</em><br>of your finances</h2>
            <p>Track every rupee. Set smarter budgets.<br>Understand where your money actually goes.</p>

            <div class="feature-item">
                <div class="feature-icon">
                    <i class="bi bi-receipt-cutoff"></i>
                </div>
                <span>Smart expense tracking</span>
            </div>
            <div class="feature-item">
                <div class="feature-icon">
                    <i class="bi bi-bullseye"></i>
                </div>
                <span>Monthly budget alerts</span>
            </div>
            <div class="feature-item">
                <div class="feature-icon">
                    <i class="bi bi-pie-chart"></i>
                </div>
                <span>Category wise insights</span>
            </div>
        </div>

        <div class="left-bottom">
            © 2026 ExpenseTracker. All rights reserved.
        </div>
    </div>

    <div class="right-panel">
        <div class="login-card">
            <p class="card-eyebrow">Welcome back</p>
            <h2 class="card-title">Sign in to your account</h2>

            <form id="account" method="post">
                <div asp-validation-summary="ModelOnly"
                     class="text-danger small mb-3"></div>

                <div class="mb-3">
                    <label asp-for="Input.Email" class="form-label">
                        Email address
                    </label>
                    <input asp-for="Input.Email"
                           class="form-control"
                           placeholder="you@example.com" />
                    <span asp-validation-for="Input.Email"
                          class="text-danger"
                          style="font-size:11px;"></span>
                </div>

                <div class="mb-1">
                    <label asp-for="Input.Password" class="form-label">
                        Password
                    </label>
                    <input asp-for="Input.Password"
                           class="form-control"
                           placeholder="Enter your password" />
                    <span asp-validation-for="Input.Password"
                          class="text-danger"
                          style="font-size:11px;"></span>
                </div>

                <div class="remember-row">
                    <div class="d-flex align-items-center gap-2">
                        <input asp-for="Input.RememberMe"
                               class="form-check-input mt-0" />
                        <label asp-for="Input.RememberMe"
                               style="font-size:13px; color:#666;">
                            Remember me
                        </label>
                    </div>
                    <a href="#" class="forgot-link">Forgot password?</a>
                </div>

                <button type="submit" class="btn-login">
                    Login
                </button>

                <div class="divider">
                    <hr /><span>or</span><hr />
                </div>

                <div class="bottom-link">
                    Don't have an account?
                    <a asp-page="./Register">Register here</a>
                </div>
            </form>
        </div>

        <div class="credit">
            Made with Love @@
            <a href="https://github.com/amitansu-jayasingh/amitansu-jayasingh"
               target="_blank">
                Amitansu Jayasingh
            </a> ❤️
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    @await Html.PartialAsync("_ValidationScriptsPartial")
</body>
</html>